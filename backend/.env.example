PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/mindguard

# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_STRONG_RANDOM_SECRET
JWT_EXPIRES_IN=7d

# Resend email API key (https://resend.com)
RESEND_API_KEY=REPLACE_WITH_YOUR_KEY

ADMIN_EMAIL=emergency-alerts@mindguard.com

# Frontend origin for CORS
CLIENT_URL=http://localhost:5173

# NODE_ENV controls seeder & debug logging (set to 'production' in prod)
NODE_ENV=development

# Seed user passwords — only used in development
SEED_PASSWORD=REPLACE_WITH_SEED_PASSWORD
